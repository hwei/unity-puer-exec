UNITY_PROJECT_PATH=F:\path\to\validation-host\Project

# Optional. Extra Unity argv tokens for a cold launch this CLI owns (JSON array of
# strings). Applied after CLI-owned -projectPath, the activation switch, and
# -logFile. Required for hosts that cannot start without a project-specific
# switch such as -force-gles30. Ignored when the CLI attaches to an already-
# running Editor. Cannot rebind -projectPath, -logFile, or -unityPuerExecControl.
# UNITY_PUER_EXEC_UNITY_LAUNCH_ARGS=["-force-gles30"]
